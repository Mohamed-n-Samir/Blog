# Database Configuration
DATABASE_URL=sqlite+aiosqlite:///./blog.db
# For PostgreSQL: postgresql+asyncpg://username:password@localhost/your_db_name

# Server Configuration
PORT=8000
HOST=0.0.0.0
ENVIRONMENT=development
DEBUG=true

# JWT Configuration (Single Token System)
SECRET_KEY=your-super-secret-key-make-it-long-and-random-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30 